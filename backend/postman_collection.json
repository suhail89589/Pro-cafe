{
  "info": {
    "name": "Pro Cafe API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"+91 98765 43210\",\n  \"address\": \"Pakwara, Moradabad 244102\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/register",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/login",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "url": {
              "raw": "http://localhost:5000/api/auth/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "profile"]
            }
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{accessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe Updated\",\n  \"phone\": \"+91 99999 88888\"\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/auth/profile",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "auth", "profile"]
            }
          }
        }
      ]
    },
    {
      "name": "Foods",
      "item": [
        {
          "name": "Get All Foods",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/api/foods",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "foods"]
            }
          }
        },
        {
          "name": "Get Foods by Category",
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/api/foods?category=Pizza",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "foods"],
              "query": [
                {
                  "key": "category",
                  "value": "Pizza"
                }
              ]
            }
          }
        },
        {
          "name": "Create Food Item (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Paneer Tikka Pizza\",\n  \"description\": \"Spiced paneer, onions, capsicum with mint drizzle.\",\n  \"category\": \"Pizza\",\n  \"image\": \"https://images.unsplash.com/photo-1513104890138-7c749659a591?q=80&w=800\",\n  \"price\": 449,\n  \"isSpecial\": true,\n  \"isVeg\": true\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/foods",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "foods"]
            }
          }
        }
      ]
    },
